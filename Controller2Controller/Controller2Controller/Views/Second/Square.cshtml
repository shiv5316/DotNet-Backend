@{
    ViewData["Title"] = "Square Result";
}

<div class="text-center">
    <h1>Square Calculator</h1>
    <p style="font-size: 24px; margin-top: 30px;">
        <strong>Number: @ViewData["Number"]</strong>
    </p>
    <p style="font-size: 24px; color: green; margin-top: 20px;">
        <strong>Square: @ViewData["Square"]</strong>
    </p>
</div>
