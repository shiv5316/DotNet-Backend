@model IEnumerable<OneToMany.Models.Student>

<h2>Students</h2>

<a href="/Student/Create">Add Student</a>

<table border="1">

    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Department</th>
    </tr>

    @foreach (var s in Model)
    {
        <tr>
            <td>@s.StudentId</td>
            <td>@s.StudentName</td>
            <td>@s.Department.DeptName</td>
        </tr>
    }

</table>